<div class="section-connector"><div class="connector-dot"></div></div>
<section class="catalog" id="catalog">
  <div class="catalog-inner">

    <div class="catalog-header reveal">
      <p class="section-eyebrow">Nos modèles</p>
      <h2 class="section-title">Choisissez<br>votre récupération.</h2>
    </div>

    <div class="catalog-grid">

      <!-- ── Produit 1 : ProRecup Pro ── -->
      <div class="catalog-card reveal-scale">
        <div class="catalog-badge-wrap">
          <span class="catalog-badge">Bestseller</span>
        </div>
        <div class="catalog-img-wrap">
          <img src="{{ 'product-1.png' | asset_url }}" alt="ProRecup Pro" class="catalog-img" loading="eager">
        </div>
        <div class="catalog-body">
          <p class="catalog-model">ProRecup Pro</p>
          <ul class="catalog-specs">
            <li>30 vitesses réglables</li>
            <li>8 embouts inclus</li>
            <li>Écran LCD tactile</li>
            <li>Livraison gratuite</li>
          </ul>
          <div class="catalog-pricing">
            <span class="catalog-old">119,99€</span>
            <span class="catalog-price">89,99€</span>
          </div>
          <button class="catalog-btn catalog-btn-pro" data-variant="{{ section.settings.variant_id_p1 | default: '53855172985175' }}">
            Ajouter au panier
          </button>
        </div>
      </div>

      <!-- ── Produit 2 : ProRecup Mini ── -->
      <div class="catalog-card reveal-scale">
        <div class="catalog-img-wrap">
          <img src="{{ 'p2-main.png' | asset_url }}" alt="ProRecup Mini" class="catalog-img" loading="lazy">
        </div>
        <div class="catalog-body">
          <p class="catalog-model">ProRecup Mini</p>
          <ul class="catalog-specs">
            <li>Vitesse variable</li>
            <li>8 embouts inclus</li>
            <li>4h d'autonomie</li>
            <li>Livraison 4,99€</li>
          </ul>
          <div class="catalog-pricing">
            <span class="catalog-price">44,99€</span>
          </div>
          {% if section.settings.variant_id_p2 != blank %}
            <button class="catalog-btn catalog-btn-mini" data-variant="{{ section.settings.variant_id_p2 }}">
              Ajouter au panier
            </button>
          {% else %}
            <button class="catalog-btn catalog-btn-mini catalog-btn-soon" disabled>
              Bientôt disponible
            </button>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function() {
  document.querySelectorAll('.catalog-btn[data-variant]:not([disabled])').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var variantId = btn.dataset.variant;
      if (!variantId) return;
      var original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Ajout en cours…';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.status) {
          btn.disabled = false;
          btn.textContent = original;
          alert(data.description || 'Erreur — vérifie le stock.');
        } else {
          btn.textContent = 'Ajouté ✓';
          if (window.showCartToast) window.showCartToast();
          setTimeout(function() {
            btn.disabled = false;
            btn.textContent = original;
          }, 2500);
        }
      })
      .catch(function() {
        btn.disabled = false;
        btn.textContent = original;
      });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Catalogue",
  "settings": [
    {
      "type": "text",
      "id": "variant_id_p1",
      "label": "Variant ID — ProRecup Pro",
      "default": "53855172985175"
    },
    {
      "type": "text",
      "id": "variant_id_p2",
      "label": "Variant ID — ProRecup Mini",
      "info": "Colle l'ID du variant après avoir créé le produit dans Shopify"
    }
  ]
}
{% endschema %}
