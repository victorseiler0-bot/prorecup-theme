{% assign p1 = section.settings.product_p1 %}
{% assign p2 = section.settings.product_p2 %}
{% assign vid1 = section.settings.variant_id_p1 | default: '53855172985175' %}
{% assign vid2 = section.settings.variant_id_p2 %}

<div class="section-connector"><div class="connector-dot"></div></div>
<section class="catalog" id="catalog">
  <div class="catalog-inner">

    <div class="catalog-header reveal">
      <p class="section-eyebrow">Nos modèles</p>
      <h2 class="section-title">Choisissez<br>votre récupération.</h2>
    </div>

    <div class="catalog-grid">

      <!-- ── Produit 1 : ProRecup Pro ── -->
      {% assign p1_url = p1.url | default: '/products/6-99-speeds-massage-gun-deep-tissue-back-massager-gun-for-athletes-muscle-massage-gun-for-body-with-4-8-massage-heads' %}
      <div class="catalog-card reveal">
        <div class="catalog-badge-wrap">
          <span class="catalog-badge">Bestseller</span>
        </div>
        <a href="{{ p1_url }}" class="catalog-img-link">
          <div class="catalog-img-wrap">
            <img src="{{ 'product-1.png' | asset_url }}" alt="ProRecup Pro" class="catalog-img" loading="eager">
          </div>
        </a>
        <div class="catalog-body">
          <a href="{{ p1_url }}" class="catalog-model-link">
            <p class="catalog-model">ProRecup Pro</p>
          </a>
          <p class="catalog-tagline">Pour les athlètes et sportifs réguliers qui veulent une récupération professionnelle.</p>
          <ul class="catalog-specs">
            <li>Poids 680 g · amplitude 12 mm</li>
            <li>30 vitesses · écran LCD tactile</li>
            <li>6h autonomie · 8 embouts</li>
            <li>Idéal : crossfit, muscu, kiné</li>
          </ul>
          <div class="catalog-pricing">
            <span class="catalog-old">119,99€</span>
            <span class="catalog-price">89,99€</span>
          </div>
          <div class="catalog-actions">
            <button class="catalog-btn catalog-btn-pro" data-variant="{{ vid1 }}">
              Acheter
            </button>
            <a href="{{ p1_url }}" class="catalog-link-detail">Voir le produit →</a>
          </div>
        </div>
      </div>

      <!-- ── Produit 2 : ProRecup Mini ── -->
      {% assign p2_url = p2.url | default: '/products/electric-massage-gun-deep-tissue-facial-massgaer-8-heads-arms-back-leg-muscle-relaxing-for-body-back-arm-sport-fitness-1' %}
      <div class="catalog-card reveal">
        <a href="{{ p2_url }}" class="catalog-img-link">
          <div class="catalog-img-wrap">
            <img src="{{ 'p2-main.png' | asset_url }}" alt="ProRecup Mini" class="catalog-img" loading="lazy">
          </div>
        </a>
        <div class="catalog-body">
          <a href="{{ p2_url }}" class="catalog-model-link">
            <p class="catalog-model">ProRecup Mini</p>
          </a>
          <p class="catalog-tagline">Pour les débutants et ceux qui bougent partout — léger, discret, silencieux.</p>
          <ul class="catalog-specs">
            <li>Poids 320 g · tient en une main</li>
            <li>6 vitesses · 8 embouts · USB-C</li>
            <li>4h autonomie · silencieux</li>
            <li>Idéal : running, yoga, bureau, voyage</li>
          </ul>
          <div class="catalog-pricing">
            <span class="catalog-price">44,99€</span>
          </div>
          <div class="catalog-actions">
            {% if vid2 != blank %}
              <button class="catalog-btn catalog-btn-pro" data-variant="{{ vid2 }}">
                Acheter
              </button>
            {% else %}
              <button class="catalog-btn catalog-btn-pro catalog-btn-soon" disabled>
                Bientôt disponible
              </button>
            {% endif %}
            <a href="{{ p2_url }}" class="catalog-link-detail">Voir le produit →</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function() {
  document.querySelectorAll('.catalog-btn[data-variant]:not([disabled])').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var variantId = btn.dataset.variant;
      if (!variantId) return;
      var original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Ajout en cours…';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.status) {
          btn.disabled = false;
          btn.textContent = original;
          alert(data.description || 'Erreur — vérifie le stock.');
        } else {
          btn.textContent = 'Ajouté ✓';
          window.location.href = '/cart';
        }
      })
      .catch(function() { btn.disabled = false; btn.textContent = original; });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Catalogue",
  "settings": [
    {
      "type": "product",
      "id": "product_p1",
      "label": "Produit 1 — ProRecup Pro"
    },
    {
      "type": "product",
      "id": "product_p2",
      "label": "Produit 2 — ProRecup Mini"
    },
    {
      "type": "text",
      "id": "variant_id_p1",
      "label": "Variant ID — ProRecup Pro",
      "default": "53855172985175"
    },
    {
      "type": "text",
      "id": "variant_id_p2",
      "label": "Variant ID — ProRecup Mini",
      "info": "Colle l'ID du variant après publication du produit"
    }
  ]
}
{% endschema %}
