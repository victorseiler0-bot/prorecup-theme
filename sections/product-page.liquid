{% assign variant = product.selected_or_first_available_variant %}
{% if product.handle contains 'electric' %}
  {% assign image_set = 'mini' %}
  {% assign display_name = 'ProRecup Mini' %}
{% else %}
  {% assign image_set = 'pro' %}
  {% assign display_name = 'ProRecup Pro' %}
{% endif %}
{% if section.settings.display_name != blank %}
  {% assign display_name = section.settings.display_name %}
{% endif %}

<section class="pp-wrap">
  <div class="pp-inner">

    <a href="/" class="pp-back">← Nos modèles</a>

    <div class="pp-layout">

      <!-- ── Galerie ── -->
      <div class="pp-gallery-col">
        <div class="product-gallery pp-gallery">
          <div class="gallery-track">
            {% if image_set == 'mini' %}
              <div class="gallery-slide active"><img src="{{ 'p2-main.png' | asset_url }}" alt="{{ display_name }}" loading="eager"></div>
              <div class="gallery-slide"><img src="{{ 'p2-2.png' | asset_url }}" alt="{{ display_name }}" loading="lazy"></div>
              <div class="gallery-slide"><img src="{{ 'p2-3.png' | asset_url }}" alt="{{ display_name }}" loading="lazy"></div>
              <div class="gallery-slide"><img src="{{ 'p2-4.png' | asset_url }}" alt="{{ display_name }}" loading="lazy"></div>
            {% else %}
              <div class="gallery-slide active"><img src="{{ 'product-2.png' | asset_url }}" alt="{{ display_name }}" loading="eager"></div>
              <div class="gallery-slide"><img src="{{ 'product-3.png' | asset_url }}" alt="{{ display_name }}" loading="lazy"></div>
              <div class="gallery-slide"><img src="{{ 'product-4.webp' | asset_url }}" alt="{{ display_name }}" loading="lazy"></div>
              <div class="gallery-slide"><img src="{{ 'product-5.png' | asset_url }}" alt="{{ display_name }}" loading="lazy"></div>
              <div class="gallery-slide"><img src="{{ 'product-6.jpg' | asset_url }}" alt="{{ display_name }}" loading="lazy"></div>
            {% endif %}
          </div>
          <div class="gallery-dots">
            {% if image_set == 'mini' %}
              <button class="gallery-dot active" data-index="0" aria-label="Photo 1"></button>
              <button class="gallery-dot" data-index="1" aria-label="Photo 2"></button>
              <button class="gallery-dot" data-index="2" aria-label="Photo 3"></button>
              <button class="gallery-dot" data-index="3" aria-label="Photo 4"></button>
            {% else %}
              <button class="gallery-dot active" data-index="0" aria-label="Photo 1"></button>
              <button class="gallery-dot" data-index="1" aria-label="Photo 2"></button>
              <button class="gallery-dot" data-index="2" aria-label="Photo 3"></button>
              <button class="gallery-dot" data-index="3" aria-label="Photo 4"></button>
              <button class="gallery-dot" data-index="4" aria-label="Photo 5"></button>
            {% endif %}
          </div>
        </div>
      </div>

      <!-- ── Info ── -->
      <div class="pp-info-col">
        <p class="pp-eyebrow">ProRecup</p>
        <h1 class="pp-title">{{ display_name }}</h1>

        <div class="pp-price-row">
          {% if variant.compare_at_price > variant.price %}
            <span class="pp-price">{{ variant.price | money_without_trailing_zeros }}</span>
            <span class="pp-old-price">{{ variant.compare_at_price | money_without_trailing_zeros }}</span>
            <span class="pp-discount-badge">-{{ variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price }}%</span>
          {% else %}
            <span class="pp-price">{{ variant.price | money_without_trailing_zeros }}</span>
          {% endif %}
        </div>

        {% if image_set == 'mini' %}
        <p class="pp-desc">Le ProRecup Mini est fait pour ceux qui bougent. Léger (320 g), silencieux et compact, il glisse dans un sac de sport ou un sac à dos de voyage. Parfait pour dénouer les tensions après une séance de running, une journée de bureau ou un vol long-courrier.</p>
        <ul class="pp-specs">
          <li><span>Poids</span><span>320 g</span></li>
          <li><span>Dimensions</span><span>17 × 8 × 4 cm</span></li>
          <li><span>Vitesses</span><span>6 niveaux</span></li>
          <li><span>Embouts inclus</span><span>8 têtes interchangeables</span></li>
          <li><span>Autonomie</span><span>4h par charge</span></li>
          <li><span>Charge</span><span>USB-C universel</span></li>
          <li><span>Niveau sonore</span><span>&lt; 45 dB (très silencieux)</span></li>
          <li><span>Pour qui</span><span>Débutants, voyageurs, sportifs du quotidien</span></li>
        </ul>
        <div class="pp-use-cases">
          <span>🏃 Running</span><span>🧘 Yoga</span><span>💼 Bureau</span><span>✈️ Voyage</span>
        </div>
        {% else %}
        <p class="pp-desc">Le ProRecup Pro est conçu pour les performances sérieuses. Avec 30 niveaux d'intensité, un écran LCD intégré et une amplitude de 12 mm, il cible en profondeur chaque groupe musculaire. C'est l'outil des athlètes, des coachs et des kinés.</p>
        <ul class="pp-specs">
          <li><span>Poids</span><span>680 g</span></li>
          <li><span>Dimensions</span><span>22 × 14 × 6 cm</span></li>
          <li><span>Vitesses</span><span>30 niveaux réglables</span></li>
          <li><span>Amplitude</span><span>12 mm (pénétration profonde)</span></li>
          <li><span>Embouts inclus</span><span>8 têtes interchangeables</span></li>
          <li><span>Autonomie</span><span>6h par charge</span></li>
          <li><span>Écran</span><span>LCD tactile intégré</span></li>
          <li><span>Pour qui</span><span>Athlètes, sportifs intensifs, kinésithérapeutes</span></li>
        </ul>
        <div class="pp-use-cases">
          <span>🏋️ Musculation</span><span>⚡ Crossfit</span><span>🏊 Natation</span><span>🩺 Kiné</span>
        </div>
        {% endif %}

        {% form 'product', product, class: 'pp-form' %}
          <input type="hidden" name="id" value="{{ variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="button" class="pp-btn-cart" data-variant="{{ variant.id }}">
            Acheter
          </button>
          <button type="submit" class="pp-btn-checkout">
            Acheter maintenant
          </button>
        {% endform %}

        <ul class="pp-trust">
          <li>Paiement sécurisé</li>
          <li>Retour 30 jours</li>
        </ul>
      </div>

    </div>
  </div>
</section>

<script>
(function() {
  var btn = document.querySelector('.pp-btn-cart');
  if (!btn) return;
  btn.addEventListener('click', function() {
    btn.disabled = true;
    btn.textContent = 'Ajout en cours…';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({id: btn.dataset.variant, quantity: 1})
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.status) {
        btn.disabled = false;
        btn.textContent = 'Ajouter au panier';
        alert(data.description || 'Erreur');
      } else {
        btn.textContent = 'Ajouté ✓';
        window.location.href = '/cart';
      }
    })
    .catch(function() { btn.disabled = false; btn.textContent = 'Ajouter au panier'; });
  });
})();
</script>

{% schema %}
{
  "name": "Page Produit",
  "settings": [
    {
      "type": "select",
      "id": "image_set",
      "label": "Photos à afficher",
      "options": [
        { "value": "pro",  "label": "ProRecup Pro" },
        { "value": "mini", "label": "ProRecup Mini" }
      ],
      "default": "pro"
    },
    {
      "type": "text",
      "id": "display_name",
      "label": "Nom affiché",
      "info": "Ex : ProRecup Pro"
    }
  ]
}
{% endschema %}
