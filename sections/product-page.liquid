{% assign variant = product.selected_or_first_available_variant %}
{% assign display_name = section.settings.display_name | default: product.title %}

<section class="pp-wrap">
  <div class="pp-inner">

    <a href="/" class="pp-back">← Nos modèles</a>

    <div class="pp-layout">

      <!-- ── Galerie ── -->
      <div class="pp-gallery-col">
        <div class="product-gallery">
          <div class="gallery-track">
            {% for image in product.images %}
              <div class="gallery-slide {% if forloop.first %}active{% endif %}">
                <img
                  src="{{ image | image_url: width: 900 }}"
                  alt="{{ image.alt | default: display_name | escape }}"
                  {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
                >
              </div>
            {% else %}
              <div class="gallery-slide active pp-no-img-wrap">
                <div class="pp-no-img">Photo à venir</div>
              </div>
            {% endfor %}
          </div>
          {% if product.images.size > 1 %}
            <div class="gallery-dots">
              {% for image in product.images %}
                <button class="gallery-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Photo {{ forloop.index }}"></button>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>

      <!-- ── Info ── -->
      <div class="pp-info-col">
        <p class="pp-eyebrow">ProRecup</p>
        <h1 class="pp-title">{{ display_name }}</h1>

        <div class="pp-price-row">
          {% if variant.compare_at_price > variant.price %}
            <span class="pp-price">{{ variant.price | money_without_trailing_zeros }}</span>
            <span class="pp-old-price">{{ variant.compare_at_price | money_without_trailing_zeros }}</span>
            <span class="pp-discount-badge">-{{ variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price }}%</span>
          {% else %}
            <span class="pp-price">{{ variant.price | money_without_trailing_zeros }}</span>
          {% endif %}
        </div>

        {% form 'product', product, class: 'pp-form', id: 'pp-form' %}
          <input type="hidden" name="id" value="{{ variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="button" class="pp-btn-cart" id="pp-add-cart" data-variant="{{ variant.id }}">
            Ajouter au panier
          </button>
          <button type="submit" formaction="/cart" class="pp-btn-checkout">
            Acheter maintenant
          </button>
        {% endform %}

        <ul class="pp-trust">
          <li>Paiement sécurisé</li>
          <li>Livraison suivie</li>
          <li>Retour 30 jours</li>
        </ul>
      </div>

    </div>
  </div>
</section>

<script>
(function() {
  /* ── Galerie ── */
  var slides  = document.querySelectorAll('.pp-wrap .gallery-slide');
  var dots    = document.querySelectorAll('.pp-wrap .gallery-dot');
  var current = 0;

  function goTo(n) {
    slides[current].classList.remove('active');
    if (dots[current]) dots[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    if (dots[current]) dots[current].classList.add('active');
  }

  dots.forEach(function(d) {
    d.addEventListener('click', function() { goTo(+d.dataset.index); });
  });

  var gallery = document.querySelector('.pp-wrap .product-gallery');
  if (gallery) {
    var startX = 0;
    gallery.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, {passive: true});
    gallery.addEventListener('touchend',   function(e) {
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
    }, {passive: true});
  }

  /* ── Ajouter au panier ── */
  var btn = document.getElementById('pp-add-cart');
  if (btn) {
    btn.addEventListener('click', function() {
      btn.disabled = true;
      btn.textContent = 'Ajout en cours…';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({id: btn.dataset.variant, quantity: 1})
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.status) {
          btn.disabled = false;
          btn.textContent = 'Ajouter au panier';
          alert(data.description || 'Erreur');
        } else {
          btn.textContent = 'Ajouté ✓';
          if (window.showCartToast) window.showCartToast();
          setTimeout(function() { window.location.href = '/cart'; }, 900);
        }
      })
      .catch(function() { btn.disabled = false; btn.textContent = 'Ajouter au panier'; });
    });
  }
})();
</script>

{% schema %}
{
  "name": "Page Produit",
  "settings": [
    {
      "type": "text",
      "id": "display_name",
      "label": "Nom affiché",
      "info": "Ex : ProRecup Pro — remplace le titre Shopify si renseigné"
    }
  ]
}
{% endschema %}
