<section class="stats-section">
  <div class="stats-inner">

    <div class="stats-grid">
      <div class="stat-block reveal">
        <span class="stat-big" data-count="4.9" data-decimals="1">0</span>
        <span class="stat-label">Note client</span>
        <span class="stat-sub">sur 504 avis vérifiés</span>
      </div>

      <div class="stat-block reveal">
        <span class="stat-big" data-count="3000" data-suffix="+">0</span>
        <span class="stat-label">Unités vendues</span>
        <span class="stat-sub">à travers le monde</span>
      </div>

      <div class="stat-block reveal">
        <span class="stat-big" data-count="0">0</span>
        <span class="stat-label">Mauvais avis</span>
        <span class="stat-sub">Zéro déception. Zéro compromis.</span>
      </div>

      <div class="stat-block reveal">
        <span class="stat-big" data-count="30" data-suffix="+">0</span>
        <span class="stat-label">Niveaux d'intensité</span>
        <span class="stat-sub">Du débutant au sportif pro</span>
      </div>
    </div>

    <p class="stats-quote reveal">
      "Plus efficace qu'une séance de kiné — disponible 24h/24, où que vous soyez."
    </p>

  </div>
</section>

{% schema %}
{
  "name": "Stats",
  "settings": []
}
{% endschema %}
