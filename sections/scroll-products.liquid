<style>
/* ── Scène sticky ── */
.sp-scene {
  height: 500vh;
  position: relative;
  background: #000;
  z-index: 1; /* sous le hero z-index:2 pour que les produits passent devant */
}
.sp-stage {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow: clip;
  background: transparent; /* laisse le noir du hero continuer */
}

/* Fond — continuation des couleurs du hero */
.sp-bg {
  position: absolute;
  inset: 0;
  background:
    /* mirroir des aurora orbs du hero en haut */
    radial-gradient(ellipse 90% 50% at 80% 0%, rgba(190,188,185,0.12) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 30% 10%, rgba(160,158,155,0.08) 0%, transparent 55%),
    /* fond doux au centre */
    radial-gradient(ellipse 70% 55% at 50% 50%, rgba(30,30,38,0.5) 0%, transparent 70%);
  pointer-events: none;
  transition: background 0.6s ease;
}

/* Panneaux */
.sp-panel {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  padding: 0 8%;
  gap: 60px;
  opacity: 0;
  pointer-events: none;
  will-change: opacity;
}

/* Visuel produit */
.sp-visual {
  overflow: visible;
  position: relative;
}
.sp-visual img {
  width: 120%;         /* dépasse du conteneur */
  max-width: none;
  display: block;
  will-change: transform, opacity;
  filter: drop-shadow(0 0 50px rgba(190,188,185,0.14));
}
/* Panel 1 : image à droite, texte à gauche */
#sp-panel-1 .sp-visual {
  display: flex;
  justify-content: flex-end;
  margin-right: -10%;
  order: 2;
}
#sp-panel-1 .sp-info { order: 1; }

/* Panel 2 : image à gauche, texte à droite */
#sp-panel-2 .sp-visual {
  display: flex;
  justify-content: flex-start;
  margin-left: -10%;
  order: 1;
}
#sp-panel-2 .sp-info { order: 2; }

/* Info texte */
.sp-info {
  display: flex;
  flex-direction: column;
  gap: 20px;
  will-change: transform, opacity;
}
.sp-info > * {
  opacity: 0;
  will-change: opacity, transform;
}
.sp-eyebrow {
  font-size: 0.7rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(185,183,180,0.85);
  font-weight: 500;
}
.sp-title {
  font-family: 'Inter', -apple-system, sans-serif;
  font-size: clamp(2.2rem, 4vw, 3.6rem);
  font-weight: 300;
  line-height: 1.05;
  color: #f5f5f7;
}
.sp-title em {
  font-style: normal;
  background: linear-gradient(135deg, #f5f5f7, rgba(245,245,247,0.35));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.sp-desc {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.45);
  line-height: 1.6;
  max-width: 420px;
}
.sp-feats {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 0;
}
.sp-feats li {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.55);
  padding-left: 18px;
  position: relative;
}
.sp-feats li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: rgba(175,173,170,0.6);
}
.sp-pricing {
  display: flex;
  align-items: center;
  gap: 12px;
}
.sp-price {
  font-size: 2rem;
  font-weight: 600;
  color: #f5f5f7;
}
.sp-old {
  font-size: 1rem;
  color: rgba(255,255,255,0.3);
  text-decoration: line-through;
}
.sp-badge {
  background: rgba(255,80,60,0.15);
  border: 1px solid rgba(255,80,60,0.3);
  color: rgba(255,100,80,0.9);
  font-size: 0.7rem;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 100px;
  letter-spacing: 0.06em;
}
.sp-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #f5f5f7;
  color: #000;
  border: none;
  font-size: 0.85rem;
  font-weight: 600;
