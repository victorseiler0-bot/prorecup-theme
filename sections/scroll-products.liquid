  transition: transform 0.2s, box-shadow 0.2s;
  text-decoration: none;
  box-shadow: 0 0 24px rgba(255,255,255,0.10), 0 4px 14px rgba(0,0,0,0.4);
}
.sp-btn:hover {
  transform: scale(1.04);
  box-shadow: 0 0 36px rgba(255,255,255,0.18), 0 6px 20px rgba(0,0,0,0.5);
}

/* Indicateur latéral */
.sp-indicator {
  position: absolute;
  right: 40px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  z-index: 10;
}
.sp-ind-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transition: background 0.4s, transform 0.4s;
}
.sp-ind-dot.active {
  background: #fff;
  transform: scale(1.3);
}
.sp-ind-line {
  width: 1px;
  height: 48px;
  background: rgba(255,255,255,0.12);
  position: relative;
  overflow: hidden;
}
.sp-ind-line::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  background: #fff;
  height: 50%;
  transition: transform 0.4s;
  transform: translateY(0%);
}
.sp-ind-line.p2::after { transform: translateY(100%); }

/* Label step */
.sp-step-label {
  position: absolute;
  left: 40px;
  bottom: 40px;
  font-size: 0.65rem;
  letter-spacing: 0.16em;
  color: rgba(255,255,255,0.25);
  z-index: 10;
}

/* Scroll hint */
.sp-scroll-hint {
  position: absolute;
  bottom: 36px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  z-index: 10;
  transition: opacity 0.5s;
}
.sp-scroll-arrow {
  display: block;
  width: 1px;
  height: 32px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
  animation: arrowDrop 1.8s ease-in-out infinite;
}
@keyframes arrowDrop {
  0%,100% { transform: scaleY(1) translateY(0); opacity: 0.4; }
  50%      { transform: scaleY(1.2) translateY(4px); opacity: 1; }
}

/* Barre fixe mobile */
.sp-bar { display: none; }

@media (max-width: 767px) {
  /* sticky-buy-bar du theme = masqué sur homepage, sp-bar le remplace */
  .sticky-buy-bar { display: none !important; }

  .sp-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 20px calc(14px + env(safe-area-inset-bottom));
    background: rgba(12,12,14,0.92);
    border-top: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transform: translateY(100%);
    transition: opacity 0.4s, transform 0.4s;
  }
  .sp-bar.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  .sp-bar-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }
  .sp-bar-name {
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(245,245,247,0.75);
    letter-spacing: 0.02em;
  }
  .sp-bar-prices {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .sp-bar-price {
    font-size: 1.05rem;
    font-weight: 700;
    color: #f5f5f7;
  }
  .sp-bar-old {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
    text-decoration: line-through;
  }
  .sp-bar-badge {
    font-size: 0.65rem;
    font-weight: 700;
    background: rgba(255,80,60,0.15);
    border: 1px solid rgba(255,80,60,0.3);
    color: rgba(255,100,80,0.9);
    padding: 2px 7px;
    border-radius: 100px;
    letter-spacing: 0.04em;
  }
  .sp-bar-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f5f5f7;
    color: #000;
    text-decoration: none;
    border-radius: 100px;
    padding: 12px 20px;
    font-size: 0.8rem;
    font-weight: 700;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.03em;
  }
}

/* ── Mobile layout — plein écran portrait ── */
@media (max-width: 767px) {
  .sp-scene { height: 600vh; }

  /* Panneau : colonne unique, image haute / texte bas */
  .sp-panel {
    display: flex;
    flex-direction: column;
    grid-template-columns: unset;
    padding: 0;
    gap: 0;
    align-items: stretch;
    justify-items: unset;
  }

  /* Image : occupe le haut de l'écran */
  .sp-visual {
    width: 100% !important;
    height: 50vh;
    display: flex !important;
    align-items: center;
    justify-content: center;
    margin: 0 !important;
    order: 0 !important;
    padding-top: calc(var(--nav-h, 64px) + 10px);
  }
  .sp-visual img {
    width: auto;
    height: 100%;
    max-height: 42vh;
    max-width: 88%;
    object-fit: contain;
    filter: drop-shadow(0 0 40px rgba(190,188,185,0.22)) !important;
  }

  /* Texte : remplit le bas */
  .sp-info {
    order: 1 !important;
    width: 100%;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding: 18px 28px 110px; /* 110px = espace barre fixe en bas */
  }

  /* Cache le bouton inline — la barre fixe le remplace */
  .sp-info .sp-btn { display: none !important; }

  .sp-eyebrow { font-size: 0.65rem; }
  .sp-title   { font-size: 2rem; line-height: 1.08; }
  .sp-price   { font-size: 1.6rem; }
  .sp-old     { font-size: 0.85rem; }
  .sp-badge   { font-size: 0.68rem; }

  /* 2 features max sur mobile */
  .sp-feats li:nth-child(n+3) { display: none; }
  .sp-feats li { font-size: 0.82rem; }
  .sp-feats { gap: 8px; }
  .sp-pricing { gap: 10px; }

  /* Reset marges négatives desktop */
  #sp-panel-1 .sp-visual { margin-right: 0 !important; }
  #sp-panel-2 .sp-visual { margin-left: 0 !important; }

  .sp-indicator { right: 14px; }
  .sp-step-label { left: 14px; bottom: 80px; font-size: 0.58rem; }
  .sp-scroll-hint { bottom: 80px; }
}
</style>

<script>
(function() {
  const scene  = document.querySelector('.sp-scene');
  const panel1 = document.getElementById('sp-panel-1');
  const panel2 = document.getElementById('sp-panel-2');
  const img1   = document.getElementById('sp-img-1');
  const img2   = document.getElementById('sp-img-2');
  const info1  = document.getElementById('sp-info-1');
  const info2  = document.getElementById('sp-info-2');
  const hint   = document.getElementById('sp-scroll-hint');
  const label  = document.getElementById('sp-step-label');
  const dot1   = document.querySelector('.sp-ind-1');
  const dot2   = document.querySelector('.sp-ind-2');
  const line   = document.querySelector('.sp-ind-line');
  if (!scene) return;

  function clamp(v, a, b) { return Math.max(a, Math.min(b, v)); }
  function prog(v, a, b)  { return clamp((v - a) / (b - a), 0, 1); }
  function ease(t) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

  function applyPanel(panel, imgEl, infoEl, active, dirImg, dirInfo, fromTop) {
    const a    = ease(active);
    const aImg = ease(clamp(active * 1.15, 0, 1));

    panel.style.opacity      = a;
    panel.style.pointerEvents = a > 0.05 ? 'auto' : 'none';

    if (imgEl) {
      const blur = (1 - aImg) * 18;
      // Panel 1 entre depuis le haut (liaison avec hero Mini)
      const tx = fromTop ? 0                        : (1 - aImg) * dirImg * 90;
      const ty = fromTop ? (1 - aImg) * -80 : 0;
      const sc = 0.82 + aImg * 0.18;
      imgEl.style.transform = `translateX(${tx}px) translateY(${ty}px) scale(${sc})`;
      imgEl.style.filter    = `blur(${blur.toFixed(1)}px) drop-shadow(0 0 50px rgba(190,188,185,0.14))`;
    }

    if (infoEl) {
      const children = infoEl.children;
      const n        = Math.max(children.length, 1);
      for (let i = 0; i < children.length; i++) {
        // stagger léger : dernier élément atteint 1 quand a=0.55
        const start = 0.18 + (i / n) * 0.22;
        const ta    = clamp((a - start) / (0.55 - start), 0, 1);
        const aEl   = ease(ta);
        children[i].style.opacity   = aEl;
        children[i].style.transform = `translateX(${(1-aEl)*dirInfo*36}px) translateY(${(1-aEl)*8}px)`;
      }
    }
  }

  function tick() {
    const rect   = scene.getBoundingClientRect();
    const travel = scene.offsetHeight - window.innerHeight;
    const p      = clamp(-rect.top / travel, 0, 1);

    // Panel 1 : entre vite (0→0.12), plateau long (0.12→0.44), sort (0.44→0.54)
    const p1in  = prog(p, 0,    0.12);
    const p1out = prog(p, 0.44, 0.54);
    const p1    = p1in * (1 - p1out);

    // Panel 2 : entre (0.54→0.68), plateau long (0.68→0.90), sort (0.90→1.0)
    const p2in  = prog(p, 0.54, 0.68);
    const p2out = prog(p, 0.90, 1.0);
    const p2    = p2in * (1 - p2out);

    applyPanel(panel1, img1, info1, p1, 1, -1, true);   // Panel 1 : image vient du haut (liaison hero)
    applyPanel(panel2, img2, info2, p2, -1, 1, false);

    // Indicateur
    const inP2 = p >= 0.54;
    if (dot1) dot1.classList.toggle('active', !inP2);
    if (dot2) dot2.classList.toggle('active', inP2);
    if (line) line.classList.toggle('p2', inP2);
    if (label) label.textContent = inP2 ? '02 / 02' : '01 / 02';

    // Cache le hint après démarrage
    if (hint) hint.style.opacity = p < 0.05 ? 1 : 0;

    // Couleur d'ambiance du fond selon le panel
    const bg = document.querySelector('.sp-bg');
    if (bg) {
      if (inP2) {
        bg.style.background = 'radial-gradient(ellipse 70% 55% at 70% 50%, rgba(175,168,155,0.10) 0%, transparent 65%), radial-gradient(ellipse 50% 45% at 25% 60%, rgba(155,148,140,0.06) 0%, transparent 65%)';
      } else {
        bg.style.background = 'radial-gradient(ellipse 70% 55% at 30% 50%, rgba(190,188,185,0.08) 0%, transparent 65%), radial-gradient(ellipse 50% 45% at 75% 60%, rgba(160,158,155,0.06) 0%, transparent 65%)';
      }
    }

    // Barre fixe mobile — toujours visible, change selon contexte
    const bar      = document.getElementById('sp-bar');
    const barName  = document.getElementById('sp-bar-name');
    const barPrice = document.getElementById('sp-bar-price');
    const barOld   = document.getElementById('sp-bar-old');
    const barBadge = document.getElementById('sp-bar-badge');
    const barBtn   = document.getElementById('sp-bar-btn');
    if (bar) {
      bar.classList.add('visible');

      const scTop    = rect.top;
      const scBottom = scTop + scene.offsetHeight;
      const inView   = scTop < window.innerHeight * 0.95 && scBottom > window.innerHeight * 0.05;
      const inScene  = inView && p > 0.04 && p < 0.96;

      if (!inScene) {
        // État par défaut → redirige vers le catalogue en bas
        if (barName)  barName.textContent  = 'ProRecup';
        if (barPrice) barPrice.textContent = '';
        if (barOld)   barOld.textContent   = '';
        if (barBadge) barBadge.textContent = '';
        if (barBtn)   { barBtn.href = '#catalog'; barBtn.textContent = 'Voir nos modèles →'; }
      } else {
        const showPro = p2 > p1;
        if (showPro) {
          if (barName)  barName.textContent  = 'ProRecup Pro';
          if (barPrice) barPrice.textContent = '89,99€';
          if (barOld)   barOld.textContent   = '119,99€';
          if (barBadge) barBadge.textContent = '-25%';
          if (barBtn)   { barBtn.href = '{{ pro_url }}'; barBtn.textContent = 'Voir le produit →'; }
        } else {
          if (barName)  barName.textContent  = 'ProRecup Mini';
          if (barPrice) barPrice.textContent = '44,99€';
          if (barOld)   barOld.textContent   = '59,99€';
          if (barBadge) barBadge.textContent = '-25%';
          if (barBtn)   { barBtn.href = '{{ mini_url }}'; barBtn.textContent = 'Voir le produit →'; }
        }
      }
    }
  }

  window.addEventListener('scroll', tick, { passive: true });
  tick();

  // ── FLIP: Mini hero → Panel 1 (même produit, clone fixe volant) ──
  (function() {
    if (window.innerWidth <= 767) return;
    const heroMini = document.querySelector('.hd-product-mini');
    const heroSec  = document.querySelector('.hero');
    const img1El   = document.getElementById('sp-img-1');
    if (!heroMini || !heroSec || !img1El) return;

    // Position de départ capturée avant tout scroll
    const SR = heroMini.getBoundingClientRect();

    // Clone fixe — survole les sections pendant la transition
    const clone = document.createElement('div');
    clone.style.cssText = 'position:fixed;pointer-events:none;z-index:9999;opacity:0;';
    const ci = document.createElement('img');
    ci.src = heroMini.querySelector('img').src;
    ci.style.cssText = 'width:100%;height:100%;object-fit:contain;display:block;filter:drop-shadow(0 0 40px rgba(175,172,168,0.30));';
    clone.appendChild(ci);
    document.body.appendChild(clone);

    let cachedTarget = null;

    function flipTick() {
      const heroH = heroSec.offsetHeight;
      const pHero = Math.max(0, Math.min(1, window.scrollY / heroH));

      const sceneEl = document.querySelector('.sp-scene');
      let pScene = 0;
      if (sceneEl) {
        const sr = sceneEl.getBoundingClientRect();
        const travel = sceneEl.offsetHeight - window.innerHeight;
        if (travel > 0) pScene = Math.max(0, Math.min(1, -sr.top / travel));
      }

      if (pHero <= 0) {
        clone.style.opacity  = '0';
        heroMini.style.opacity = '';
        cachedTarget = null;
        return;
      }

      // Dès que la section est sticky, on mémorise la vraie position de l'image Panel 1
      if (!cachedTarget && pScene > 0) {
        cachedTarget = img1El.getBoundingClientRect();
      }

      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const TR = cachedTarget || {
        left: vw * 0.50, top: vh * 0.10,
        width: vw * 0.46, height: vh * 0.75
      };

      // t : hero exit 0→75%, puis Panel 1 entry 75→100%
      const rawT = pHero < 1
        ? pHero * 0.75
        : 0.75 + Math.min(pScene / 0.12, 1) * 0.25;
      const t = ease(Math.min(rawT, 1));

      clone.style.left      = (SR.left   + (TR.left   - SR.left)   * t) + 'px';
      clone.style.top       = (SR.top    + (TR.top    - SR.top)    * t) + 'px';
      clone.style.width     = (SR.width  + (TR.width  - SR.width)  * t) + 'px';
      clone.style.height    = (SR.height + (TR.height - SR.height) * t) + 'px';
      clone.style.transform = `rotate(${11 * (1 - t)}deg)`;
      clone.style.opacity   = String(Math.max(0, 1 - pScene / 0.10));

      heroMini.style.opacity = '0';
    }

    window.addEventListener('scroll', flipTick, { passive: true });
    flipTick();
  })();
})();
</script>

