<style>
/* ── Scène sticky ── */
.sp-scene {
  height: 500vh;
  position: relative;
  background: #000;
  z-index: 1; /* sous le hero z-index:2 pour que les produits passent devant */
}
.sp-stage {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow: clip;
  background: transparent; /* laisse le noir du hero continuer */
}

/* Fond avec léger dégradé — même gris lux que le hero */
.sp-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 55% at 30% 50%, rgba(190,188,185,0.08) 0%, transparent 65%),
    radial-gradient(ellipse 50% 45% at 75% 60%, rgba(160,158,155,0.06) 0%, transparent 65%);
  pointer-events: none;
}

/* Panneaux */
.sp-panel {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  padding: 0 8%;
  gap: 60px;
  opacity: 0;
  pointer-events: none;
  will-change: opacity;
}

/* Visuel produit */
.sp-visual {
  overflow: visible;
  position: relative;
}
.sp-visual img {
  width: 120%;         /* dépasse du conteneur */
  max-width: none;
  display: block;
  will-change: transform, opacity;
  filter: drop-shadow(0 0 50px rgba(200,200,215,0.14));
}
#sp-panel-1 .sp-visual {
  display: flex;
  justify-content: flex-end;
  margin-right: -10%;  /* tire l'image vers la droite hors du panneau */
}
#sp-panel-2 .sp-visual {
  display: flex;
  justify-content: flex-start;
  margin-left: -10%;   /* tire l'image vers la gauche hors du panneau */
}

/* Info texte */
.sp-info {
  display: flex;
  flex-direction: column;
  gap: 20px;
  will-change: transform, opacity;
}
.sp-info > * {
  opacity: 0;
  will-change: opacity, transform;
}
.sp-eyebrow {
  font-size: 0.7rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(190,190,205,0.85);
  font-weight: 500;
}
.sp-title {
  font-family: 'Inter', -apple-system, sans-serif;
  font-size: clamp(2.2rem, 4vw, 3.6rem);
  font-weight: 300;
  line-height: 1.05;
  color: #f5f5f7;
}
.sp-title em {
  font-style: normal;
  background: linear-gradient(135deg, #f5f5f7, rgba(245,245,247,0.35));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.sp-feats {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 0;
}
.sp-feats li {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.55);
  padding-left: 18px;
  position: relative;
}
.sp-feats li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: rgba(180,180,195,0.6);
}
.sp-pricing {
  display: flex;
  align-items: center;
  gap: 12px;
}
.sp-price {
  font-size: 2rem;
  font-weight: 600;
  color: #f5f5f7;
}
.sp-old {
  font-size: 1rem;
  color: rgba(255,255,255,0.3);
  text-decoration: line-through;
}
.sp-badge {
  background: rgba(255,80,60,0.15);
  border: 1px solid rgba(255,80,60,0.3);
  color: rgba(255,100,80,0.9);
  font-size: 0.7rem;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 100px;
  letter-spacing: 0.06em;
}
.sp-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #f5f5f7;
  color: #000;
  border: none;
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  padding: 14px 28px;
  border-radius: 100px;
  width: fit-content;
  transition: transform 0.2s, box-shadow 0.2s;
  text-decoration: none;
  box-shadow: 0 0 24px rgba(255,255,255,0.10), 0 4px 14px rgba(0,0,0,0.4);
}
.sp-btn:hover {
  transform: scale(1.04);
  box-shadow: 0 0 36px rgba(255,255,255,0.18), 0 6px 20px rgba(0,0,0,0.5);
}

/* Indicateur latéral */
.sp-indicator {
  position: absolute;
  right: 40px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  z-index: 10;
}
.sp-ind-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transition: background 0.4s, transform 0.4s;
}
.sp-ind-dot.active {
  background: #fff;
  transform: scale(1.3);
}
.sp-ind-line {
  width: 1px;
  height: 48px;
  background: rgba(255,255,255,0.12);
  position: relative;
  overflow: hidden;
}
.sp-ind-line::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  background: #fff;
  height: 50%;
  transition: transform 0.4s;
  transform: translateY(0%);
}
.sp-ind-line.p2::after { transform: translateY(100%); }

/* Label step */
.sp-step-label {
  position: absolute;
  left: 40px;
  bottom: 40px;
  font-size: 0.65rem;
  letter-spacing: 0.16em;
  color: rgba(255,255,255,0.25);
  z-index: 10;
}

/* Scroll hint */
.sp-scroll-hint {
  position: absolute;
  bottom: 36px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  z-index: 10;
  transition: opacity 0.5s;
}
.sp-scroll-arrow {
  display: block;
  width: 1px;
  height: 32px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
  animation: arrowDrop 1.8s ease-in-out infinite;
}
@keyframes arrowDrop {
  0%,100% { transform: scaleY(1) translateY(0); opacity: 0.4; }
  50%      { transform: scaleY(1.2) translateY(4px); opacity: 1; }
}

/* ── Mobile ── */
@media (max-width: 767px) {
  .sp-scene { height: 600vh; }

  .sp-panel {
    grid-template-columns: 1fr;
    padding: 52px 7% 28px;
    gap: 10px;
    align-content: start;
    justify-items: center;
  }

  /* Image en haut, info en bas */
  #sp-panel-1 .sp-visual,
  #sp-panel-2 .sp-visual { order: 1; }
  #sp-panel-1 .sp-info,
  #sp-panel-2 .sp-info   { order: 2; }

  .sp-visual {
    width: 100%;
    display: flex;
    justify-content: center;
  }
  .sp-visual img {
    width: 70%;
    max-height: 32vh;
    object-fit: contain;
  }
  /* Reset marges négatives desktop */
  #sp-panel-1 .sp-visual { margin-right: 0; }
  #sp-panel-2 .sp-visual { margin-left: 0; }

  .sp-info {
    width: 100%;
    align-items: flex-start;
    gap: 10px;
  }

  .sp-eyebrow { font-size: 0.62rem; }
  .sp-title   { font-size: 1.6rem; line-height: 1.1; }
  .sp-price   { font-size: 1.4rem; }
  .sp-old     { font-size: 0.85rem; }

  /* N'affiche que les 2 premières features sur mobile */
  .sp-feats li:nth-child(n+3) { display: none; }
  .sp-feats li { font-size: 0.78rem; }
  .sp-feats { gap: 7px; }

  .sp-pricing { gap: 8px; }

  .sp-btn {
    padding: 12px 24px;
    font-size: 0.82rem;
  }

  .sp-indicator { right: 14px; }
  .sp-step-label { left: 14px; bottom: 16px; font-size: 0.58rem; }
  .sp-scroll-hint { bottom: 16px; }
}
</style>

<script>
(function() {
  const scene  = document.querySelector('.sp-scene');
  const panel1 = document.getElementById('sp-panel-1');
  const panel2 = document.getElementById('sp-panel-2');
  const img1   = document.getElementById('sp-img-1');
  const img2   = document.getElementById('sp-img-2');
  const info1  = document.getElementById('sp-info-1');
  const info2  = document.getElementById('sp-info-2');
  const hint   = document.getElementById('sp-scroll-hint');
  const label  = document.getElementById('sp-step-label');
  const dot1   = document.querySelector('.sp-ind-1');
  const dot2   = document.querySelector('.sp-ind-2');
  const line   = document.querySelector('.sp-ind-line');
  if (!scene) return;

  function clamp(v, a, b) { return Math.max(a, Math.min(b, v)); }
  function prog(v, a, b)  { return clamp((v - a) / (b - a), 0, 1); }
  function ease(t) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

  function applyPanel(panel, imgEl, infoEl, active, dirImg, dirInfo) {
    const a    = ease(active);
    const aImg = ease(clamp(active * 1.15, 0, 1));          // image légèrement en avance
    const aTxt = a > 0.4 ? ease(prog(a, 0.4, 1)) : 0;      // texte décalé après

    panel.style.opacity      = a;
    panel.style.pointerEvents = a > 0.05 ? 'auto' : 'none';

    if (imgEl) {
      const blur = (1 - aImg) * 18;                          // blur 18px → 0
      const tx   = (1 - aImg) * dirImg * 90;
      const sc   = 0.78 + aImg * 0.22;                      // scale 0.78 → 1
      imgEl.style.transform = `translateX(${tx}px) scale(${sc})`;
      imgEl.style.filter    = `blur(${blur.toFixed(1)}px) drop-shadow(0 0 50px rgba(200,200,215,0.14))`;
    }

    if (infoEl) {
      const children = infoEl.children;
      for (let i = 0; i < children.length; i++) {
        const delay = i * 0.12;                              // stagger par élément
        const ta    = clamp((a - 0.32 - delay) / 0.45, 0, 1);
        const aEl   = ease(ta);
        children[i].style.opacity   = aEl;
        children[i].style.transform = `translateX(${(1-aEl)*dirInfo*40}px) translateY(${(1-aEl)*10}px)`;
      }
    }
  }

  function tick() {
    const rect   = scene.getBoundingClientRect();
    const travel = scene.offsetHeight - window.innerHeight;
    const p      = clamp(-rect.top / travel, 0, 1);

    // Panel 1 : entre 0→0.45, sort 0.45→0.58
    const p1in  = prog(p, 0,    0.22);
    const p1out = prog(p, 0.42, 0.56);
    const p1    = p1in * (1 - p1out);

    // Panel 2 : entre 0.56→0.78, sort 0.88→1
    const p2in  = prog(p, 0.56, 0.78);
    const p2out = prog(p, 0.88, 1.0);
    const p2    = p2in * (1 - p2out);

    applyPanel(panel1, img1, info1, p1, 1, -1);
    applyPanel(panel2, img2, info2, p2, -1, 1);

    // Indicateur
    const inP2 = p >= 0.56;
    if (dot1) dot1.classList.toggle('active', !inP2);
    if (dot2) dot2.classList.toggle('active', inP2);
    if (line) line.classList.toggle('p2', inP2);
    if (label) label.textContent = inP2 ? '02 / 02' : '01 / 02';

    // Cache le hint après démarrage
    if (hint) hint.style.opacity = p < 0.05 ? 1 : 0;
  }

  window.addEventListener('scroll', tick, { passive: true });
  tick();
})();
</script>

