<section class="hero" id="hero">

  <div class="hero-overlay"></div>

  <div class="hero-bg-gradient" aria-hidden="true">
    <div class="aurora-orb aurora-orb-1"></div>
    <div class="aurora-orb aurora-orb-2"></div>
    <div class="aurora-orb aurora-orb-3"></div>
  </div>

  <div class="hero-grid">

    <!-- GAUCHE : texte -->
    <div class="hero-left">

      <div class="hero-badge reveal">
        <span class="hero-badge-dot"></span>
        Récupération Premium
      </div>

      <h1 class="hero-title reveal">
        Performez.<br>
        Récupérez.<br>
        <em>Dominez.</em>
      </h1>

      <a href="#catalog" class="hero-cta reveal">Acheter maintenant →</a>

      <p class="hero-sub reveal">
        Deux modèles pensés pour les exigeants.<br>Livraison rapide · Retour 30 jours.
      </p>

      <div class="hero-metrics reveal">
        <div class="hm-item">
          <span class="hm-val">★ 4.9</span>
          <span class="hm-lab">Note clients</span>
        </div>
        <span class="hm-sep"></span>
        <div class="hm-item">
          <span class="hm-val">5 000+</span>
          <span class="hm-lab">Clients</span>
        </div>
        <span class="hm-sep"></span>
        <div class="hm-item">
          <span class="hm-val">30 J</span>
          <span class="hm-lab">Retour gratuit</span>
        </div>
      </div>

      <div class="hero-scroll-hint reveal">
        <span class="hero-scroll-line"></span>
        <span class="hero-scroll-label">Découvrir</span>
      </div>

    </div>

    <div class="hero-col-sep" aria-hidden="true"></div>

    <!-- DROITE : produits -->
    <div class="hero-right" aria-hidden="true">

      <div class="hd-smoke hd-smoke-b1"></div>
      <div class="hd-smoke hd-smoke-b2"></div>

      <div class="hd-product hd-product-pro">
        <img src="{{ 'hero-pro.png' | asset_url }}" alt="ProRecup Pro" loading="eager">
        <div class="hd-tag">
          <span class="hd-tag-name">ProRecup Pro</span>
          <span class="hd-tag-price">89,99€ <s>119,99€</s></span>
        </div>
        <div class="hd-chip hd-chip-1">30 vitesses</div>
        <div class="hd-chip hd-chip-2">LCD tactile</div>
      </div>

      <div class="hd-product hd-product-mini">
        <img src="{{ 'hero-mini.png' | asset_url }}" alt="ProRecup Mini" loading="eager">
        <div class="hd-tag hd-tag-r">
          <span class="hd-tag-name">ProRecup Mini</span>
          <span class="hd-tag-price">44,99€</span>
        </div>
        <div class="hd-chip hd-chip-3">4h autonomie</div>
        <div class="hd-chip hd-chip-4">8 embouts</div>
      </div>

      <div class="hd-smoke hd-smoke-f1"></div>

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "settings": []
}
{% endschema %}
