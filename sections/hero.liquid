<section class="hero" id="hero">
  <div class="hero-content">
    <p class="hero-eyebrow reveal">Récupération musculaire</p>
    <h1 class="hero-title reveal">
      Performez.<br>
      Récupérez.<br>
      <em>Dominez.</em>
    </h1>
    <p class="hero-subtitle reveal">Le pistolet de massage qui change tout.</p>
    <a href="#buy" class="hero-btn reveal">Découvrir</a>
  </div>

  <div class="hero-3d" id="hero-canvas-container">
    <canvas id="three-canvas"></canvas>
    <p class="canvas-hint">Faites glisser pour pivoter</p>
  </div>

  <div class="hero-scroll-indicator">
    <span></span>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": []
}
{% endschema %}
