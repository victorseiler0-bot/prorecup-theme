<section class="hero" id="hero">

  <div class="hero-overlay"></div>

  <div class="hero-bg-gradient" aria-hidden="true">
    <div class="aurora-orb aurora-orb-1"></div>
    <div class="aurora-orb aurora-orb-2"></div>
    <div class="aurora-orb aurora-orb-3"></div>
  </div>

  <div class="hero-content">
    <h1 class="hero-title reveal">
      Performez.<br>
      Récupérez.<br>
      <em>Dominez.</em>
    </h1>

    <p class="hero-subtitle reveal">
      Deux modèles. Un seul objectif : transformer votre récupération en avantage compétitif.
    </p>

    <div class="hero-actions reveal">
      <a href="#catalog" class="hero-btn">Choisir mon modèle →</a>
      <a href="#features" class="hero-btn-ghost">En savoir plus →</a>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "settings": []
}
{% endschema %}
